[bar/transparent]

;-- Dimensions --;
width = 100%
height = 40
offset-x = 0%
offset-y = 0%
border-size = 6
fixed-center = true
padding-left = 2
padding-right = 2

;-- Location --;
bottom = false
monitor = eDP-1

;-- Font --;
font-0 = Hack:size=22;3
font-1 = "Font Awesome 5 Free:style 5 Free:style=Solid:pixelsize=24;3"
font-2 = "Font Awesome 5 Free:style=Regular:pixelsize=24;3"
font-3 = "Font Awesome 5 Brands:pixelsize=24;3"

;-- Colors --;
background = 0
foreground = #afafaf
border-color = 0

;-- Modules --;
module-margin = 1 
modules-left = cpu memory date 
modules-center = i3
modules-right = wlan volume battery time

[module/i3]
type = internal/i3
pin-workspaces = true
strip-wsnumbers = true
enable-scroll = false
label-unfocused-foreground = #afafaf
label-focused-foreground = #c5a9f9
label-urgent-foreground = #ff0000

[module/time]
type = internal/date

interval = 1.0

date =  %H:%M

[module/date]
type = internal/date
date =  %e %B - %A
label = %date%


[module/battery]
type = internal/battery

battery = BAT0

poll-interval = 1

full-at = 95

label-discharging = %percentage%%
label-charging = %percentage%%
label-full = %percentage%%

format-discharging = <ramp-capacity> <label-discharging>
format-full = <ramp-capacity> <label-full>
format-charging =  <label-charging>

ramp-capacity-0 = 
ramp-capacity-1 = 
ramp-capacity-2 = 
ramp-capacity-3 = 
ramp-capacity-4 = 

[module/volume]
type = internal/volume

format-volume = <ramp-volume> <label-volume>
format-muted =  0%

ramp-volume-0 = 
ramp-volume-1 = 
ramp-volume-2 = 

[module/wlan]
type = internal/network

interface = wlp2s0

interval = 5

label-connected =  %essid%
label-disconnected =  Not Connected

[module/cpu]
type = internal/cpu
label =  %percentage%%


[module/memory]
type = internal/memory
label =  %gb_used%

[module/network]
type = internal/network
interface = wlp2s0
label-connected =  %downspeed% |  %upspeed%
