;; --- Colors --- 

[color]
shade1 = #4A148C
shade2 = #6A1B9A
shade3 = #7B1FA2
shade4 = #8E24AA
shade5 = #9C27B0
shade6 = #AB47BC
shade7 = #BA68C8
shade8 = #CE93D8

background = #1D1F28
foreground = #F7F7F7
accent =  #8E24AA
modulefg = #F7F7F7
modulefg-alt = #F7F7F7

trans = #00000000
white = #FFFFFF
black = #000000

red = 		#E53935
pink = 		#D81B60
purple = 	#8E24AA
deep-purple = 	#5E35B1
indigo = 	#3949AB
blue = 		#1E88E5
light-blue = 	#039BE5
cyan = 		#00ACC1
teal = 		#00897B
green = 	#43A047
light-green = 	#7CB342
lime = 		#C0CA33
yellow = 	#FDD835
amber = 	#FFB300
orange = 	#FB8C00
deep-orange = 	#F4511E
brown = 	#6D4C41
grey = 		#757575
blue-gray = 	#546E7A

;; --- Bar ---

[bar/main]
monitor = eDP1
monitor-strict = false
override-redirect = false

bottom = false
fixed-center = true
width = 100%
height = 60
offset-x = 0%
offset-y = 0%

background = 0
foreground = #AFAFAF

radius-top = 0.0
radius-bottom = 0.0

overline-size = 2
overline-color = ${color.accent}

padding = 0
module-margin-left = 0
module-margin-right = 0

font-0 = Hack:size=18;3
font-1 = "Font Awesome 5 Free:style 5 Free:style=Solid:pixelsize=24;3"
font-2 = "Font Awesome 5 Free:style=Regular:pixelsize=18;3"
font-3 = "Font Awesome 5 Brands:pixelsize=18;3"

module-margin = 1

modules-left = title
modules-center = i3
modules-right = network alsa cpu-graph memory battery date

separator = 
spacing = 0
dim-value = 1.0
wm-name = 
locale = 

tray-position = none
tray-detached = false
tray-maxsize = 16
tray-transparent = false
tray-background = ${color.background}
tray-offset-x = 0
tray-offset-y = 0
tray-padding = 0
tray-scale = 1.0

enable-ipc = true

[settings]
throttle-output = 5
throttle-output-for = 10
throttle-input-for = 30

screenchange-reload = false
compositing-background = source
compositing-foreground = over
compositing-overline = over
compositing-underline = over
compositing-border = over

pseudo-transparency = false

;; --- Modules ---

[module/title]
type = internal/xwindow

format = <label>
format-background = ${color.shade2}
format-foreground = ${color.modulefg}
format-padding = 2

label = %title%
label-maxlen = 50

label-empty = Arch Linux

[module/i3]
type = internal/i3
index-sort = true
enable-click = true
fuzzy-match = true
wrapping-scroll = false
strip-wsnumbers = true
pint-workspaces = true

label-focused-padding = 2
label-unfocused-padding = 2

[module/alsa]
type = internal/alsa

format-volume = <ramp-volume> <label-volume>
format-volume-background = ${color.shade5}
format-volume-foreground = ${color.modulefg}
format-volume-padding = 2

label-volume = %percentage%%

format-muted-prefix = 
label-muted = " Muted"
format-muted-background = ${color.shade5}
format-muted-foreground = ${color.modulefg}
format-muted-padding = 2

ramp-volume-0 = 
ramp-volume-1 = 
ramp-volume-2 = 

[module/memory]
type = internal/memory
label =  %gb_used%

format-background = ${color.shade3}
format-foreground = ${color.modulefg}
format-padding = 2

[module/cpu-graph]
type = internal/cpu
interval = 0.08
format = " <ramp-coreload>"
format-background = ${color.shade4}
format-foreground = ${color.modulefg}
format-underline = ${colors.adapta-cyan}
format-margin = ${margin.for-modules}
format-padding = 2
ramp-coreload-0 = ▁
ramp-coreload-0-foreground = ${color.cyan}
ramp-coreload-1 = ▂
ramp-coreload-1-foreground = ${color.green}
ramp-coreload-2 = ▃
ramp-coreload-2-foreground = ${color.light-green}
ramp-coreload-3 = ▄
ramp-coreload-3-foreground = ${color.light-green}
ramp-coreload-4 = ▅
ramp-coreload-4-foreground = ${color.yellow}
ramp-coreload-5 = ▆
ramp-coreload-5-foreground = ${color.yellow}
ramp-coreload-6 = ▇
ramp-coreload-6-foreground = ${color.red}
ramp-coreload-7 = █
ramp-coreload-7-foreground = ${color.red}
ramp-coreload-font = 3

[module/date]
type = internal/date
date =  %e %B - %A
time =  %H:%M
interval = 1.0

format = <label>
format-background = ${color.shade2}
format-foreground = ${color.modulefg}
format-padding = 2
label = %date% %time%

[module/battery]
type = internal/battery
battery = BAT0
poll-interval = 1
full-at = 95

label-discharging = %percentage%%
label-charging = %percentage%%
label-full = %percentage%%

format-discharging = <ramp-capacity> <label-discharging>
format-full = <ramp-capacity> <label-full>
format-charging =  <label-charging>
format-padding = 2

ramp-capacity-0 =  
ramp-capacity-1 = 
ramp-capacity-2 = 
ramp-capacity-3 = 
ramp-capacity-4 = 

format-background = ${color.shade5}
format-foreground = ${color.modulefg}
format-discharging-background = ${color.shade5}
format-discharging-foreground = ${color.modulefg}
format-charging-background = ${color.shade5}
format-charging-foregroudn = ${color.modulefg}

[module/network]
type = internal/network
interface = wlp2s0

interval = 1.0
accumulate-stats = true
unknown-as-up = true

format-connected = <label-connected>
format-connected-background = ${color.shade6}
format-connected-foreground = ${color.modulefg}
format-connected-padding = 2

format-disconnected = <label-disconnected>
format-disconnected-background = ${color.shade6}
format-disconnected-foreground = ${color.modulefg}
format-disconnected-padding = 2

label-connected = "↑ %upspeed% ↓ %downspeed% ⇄  %essid%"
label-disconnected =  Not Connected


